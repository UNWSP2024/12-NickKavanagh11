import tkinter as tk
from tkinter import messagebox

def calculate_mpg():
    try:
        gallons = float(entry_gallons.get())
        miles = float(entry_miles.get())

        if gallons == 0:
            raise ValueError

        mpg = miles / gallons
        result_label.config(text=f"MPG: {mpg:.2f}")
    except:
        messagebox.showerror("Error", "Enter valid numbers.")

root = tk.Tk()
root.title("MPG Calculator")

tk.Label(root, text="Gallons:").grid(row=0, column=0)
entry_gallons = tk.Entry(root)
entry_gallons.grid(row=0, column=1)

tk.Label(root, text="Miles:").grid(row=1, column=0)
entry_miles = tk.Entry(root)
entry_miles.grid(row=1, column=1)

tk.Button(root, text="Calculate MPG", command=calculate_mpg).grid(row=2, column=0, columnspan=2)

result_label = tk.Label(root, text="MPG: ")
result_label.grid(row=3, column=0, columnspan=2)

root.mainloop()
